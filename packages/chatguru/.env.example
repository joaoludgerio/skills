# Modo de operacao: "full" (padrao) ou "readonly"
# - full: todas as tools (API + Playwright) — requer API_KEY
# - readonly: apenas tools de leitura (Playwright) — nao requer API_KEY
CHATGURU_MODE=full

# Servidor ChatGuru (obrigatorio em ambos os modos)
CHATGURU_SERVER=17

# Credenciais da API — obrigatorias apenas no modo full
# (Peca ao admin — Configuracoes > Celulares no painel ChatGuru)
CHATGURU_API_KEY=sua_chave_aqui
CHATGURU_ACCOUNT_ID=seu_account_id_aqui
CHATGURU_PHONE_ID=seu_phone_id_aqui
