# outlook-mcp — variáveis de ambiente opcionais
#
# Se não definidas, o app usa as credenciais padrão do Azure já configurado.
# Defina estas variáveis apenas se quiser usar seu próprio app Azure.
#
# Para criar um app Azure: https://portal.azure.com → App registrations
# Escopos necessários (Delegated): Mail.Send, Mail.Read, Calendars.ReadWrite, People.Read

OUTLOOK_CLIENT_ID=seu-application-client-id-aqui
OUTLOOK_TENANT_ID=seu-directory-tenant-id-aqui
