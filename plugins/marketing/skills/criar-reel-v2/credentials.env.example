# Renomeie este arquivo para credentials.env e preencha com as SUAS chaves.
# NUNCA commite o credentials.env (ja esta no .gitignore).

# --- HeyGen (avatar falante) — https://app.heygen.com/settings/api
HEYGEN_API_KEY=
# IDs do SEU avatar e da SUA voz clonada no HeyGen
# (liste com: GET https://api.heygen.com/v2/avatars e /v2/voices usando sua chave)
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# --- OpenAI (frames e thumb via GPT Image 2) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Kling (fallback de B-roll, opcional)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- Higgsfield (B-rolls): nao usa chave aqui.
# Instale o CLI (npm install -g @higgsfield/cli) e rode `hf auth login` uma vez.
# Geracao de video exige plano Basic ou superior.
