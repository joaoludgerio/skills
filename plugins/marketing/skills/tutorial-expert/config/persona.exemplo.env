# Persona do influencer de IA da serie do @expertintegrado.
# Copiar pra C:/MCPs/tutorial-expert-persona.env (FORA do plugin: sobrevive a updates)
# e preencher. Nao commitar o arquivo real se ele ganhar dados sensiveis.

PERSONA_NOME=
SERIE_NOME=IA no Comercial em 60 Segundos
ELEVEN_VOICE_ID=
HEYGEN_AVATAR_ID=
VOICE_REF=C:/MCPs/tutorial-expert-voice-ref.wav
CTA_CONTA=@expertintegrado
# Opcional: linha Style do ASS pro compose_reel (--sub-style). Vazio = estilo default.
SUB_STYLE=
# sim | nao : enquanto "nao", todo episodio sai marcado como PILOTO no manifest.
APROVADA_PELO_ERIC=nao
