# Copie este arquivo para config/chaves.env e preencha com SUAS chaves.
# O agente faz isso no onboarding. NUNCA suba o chaves.env pra lugar nenhum.

# OpenAI - gera as imagens do b-roll (gpt-image-2). Obrigatoria.
# Pegue em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# HeyGen - gera o avatar que apresenta o reels. Obrigatoria.
# Pegue em: app.heygen.com -> Settings -> API
HEYGEN_API_KEY=...

# ElevenLabs - SO se quiser usar voz clonada no avatar. Opcional.
# O padrao usa a voz nativa do HeyGen (nao precisa desta chave).
# Pegue em: https://elevenlabs.io -> Profile -> API Key
ELEVENLABS_API_KEY=

# Pasta onde salvar os videos prontos. Deixe em branco pra usar a pasta ./saida da skill.
OUTPUT_DIR=
